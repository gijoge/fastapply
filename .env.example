# FastApply Configuration
# Copy this to .env and fill in your values

# OpenAI API Key (required for AI features)
OPENAI_API_KEY=sk-your-key-here

# Model selection (gpt-4o-mini is fast and cheap; gpt-4o for higher quality)
OPENAI_MODEL=gpt-4o-mini

# Job search location
DEFAULT_LOCATION=Minneapolis, MN

# File paths
DB_PATH=data/applications.db
RESUME_PATH=data/resume.txt

# Your name and contact info (used in cover letters)
APPLICANT_NAME=Your Name
APPLICANT_EMAIL=your.email@gmail.com
APPLICANT_PHONE=(651) 000-0000
